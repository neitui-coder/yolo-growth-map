/* avatar-picker: 头像选择弹窗样式 */

.avatar-picker-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 150;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-picker-box {
  background: #fff;
  border-radius: 32rpx;
  padding: 48rpx;
  width: 600rpx;
  max-height: 70vh;
  overflow-y: auto;
}

.picker-title {
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
  color: #1f2937;
}

.avatar-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24rpx;
}

.avatar-choice {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 50%;
  border: 6rpx solid transparent;
  background: #fef3c7;
}

.avatar-choice.current {
  border-color: #f97316;
  box-shadow: 0 0 0 6rpx rgba(249, 115, 22, 0.3);
}
