/* goal-card: 年度目标卡片样式 */

.goal-card {
  margin: 32rpx;
  border-radius: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border: 1rpx solid #fbbf24;
}

.goal-title {
  font-size: 28rpx;
  color: #92400e;
  margin-bottom: 16rpx;
  font-weight: 600;
}

.goal-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #78350f;
}

.btn-set-goal {
  margin: 32rpx;
  background: #fff;
  border: 4rpx dashed #fbbf24;
  border-radius: 24rpx;
  padding: 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #92400e;
  text-align: center;
}
