/* profile-header: 用户资料头部样式 */

.profile-header {
  background: linear-gradient(135deg, #f97316 0%, #ef4444 50%, #ec4899 100%);
  padding: 64rpx 40rpx 48rpx;
  color: #fff;
  text-align: center;
}

.profile-avatar-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 24rpx;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 8rpx solid rgba(255, 255, 255, 0.5);
  background: #fef3c7;
}

.avatar-edit-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 52rpx;
  height: 52rpx;
  background: #fff;
  border-radius: 50%;
  border: 4rpx solid #f97316;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.edit-icon {
  font-size: 22rpx;
}

.profile-name {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.profile-days {
  font-size: 26rpx;
  opacity: 0.85;
  margin-bottom: 32rpx;
}

.profile-stats {
  display: flex;
  justify-content: center;
  gap: 48rpx;
  margin-bottom: 32rpx;
}

.stat-badge {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  padding: 12rpx 32rpx;
  font-size: 26rpx;
}

.profile-motto {
  font-style: italic;
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 24rpx;
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.skill-tag {
  background: rgba(255, 255, 255, 0.25);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  border-radius: 32rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}
