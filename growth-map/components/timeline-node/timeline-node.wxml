<!--
  timeline-node: 时间轴节点
  - 中间竖线 + 圆点
  - 奇偶节点左右交替显示卡片
  - 卡片内含：日期、类型标签（彩色）、描述文字
  - 可选显示最多 3 张图片缩略图
  - 点击卡片触发 nodetap 事件（编辑该节点）
-->
<view class="timeline-node {{typeConfig.className}} {{isOdd ? 'odd' : 'even'}}" bindtap="onNodeTap">
  <view class="timeline-dot"></view>
  <view class="node-card">
    <text class="node-date">{{formattedDate}}</text>
    <view class="node-type-label">{{typeConfig.label}}</view>
    <text class="node-desc">{{node.desc}}</text>
    <!-- 图片缩略图 -->
    <view wx:if="{{node.images && node.images.length > 0}}" class="node-images">
      <image
        wx:for="{{node.images}}"
        wx:if="{{index < 3}}"
        wx:key="*this"
        class="node-img-thumb"
        src="{{item}}"
        mode="aspectFill"
      />
    </view>
  </view>
</view>
