/* timeline-node: 时间轴节点样式 */

.timeline-node {
  position: relative;
  width: 100%;
  margin-bottom: 48rpx;
  display: flex;
  animation: nodeIn 0.4s ease forwards;
  opacity: 0;
  transform: translateY(20rpx);
}

@keyframes nodeIn {
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 奇数节点靠左 */
.timeline-node.odd {
  justify-content: flex-start;
  padding-right: calc(50% + 40rpx);
}

/* 偶数节点靠右 */
.timeline-node.even {
  justify-content: flex-end;
  padding-left: calc(50% + 40rpx);
}

.timeline-node.odd .node-card {
  text-align: right;
}

.timeline-node.even .node-card {
  text-align: left;
}

/* 中心圆点 */
.timeline-dot {
  position: absolute;
  left: 50%;
  top: 32rpx;
  width: 28rpx;
  height: 28rpx;
  border-radius: 50%;
  transform: translateX(-50%);
  border: 6rpx solid #fff;
  z-index: 5;
}

/* 节点卡片 */
.node-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 1rpx solid #f0f0f0;
  width: 100%;
}

.node-date {
  font-size: 22rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
  display: block;
}

.node-type-label {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.node-desc {
  font-size: 28rpx;
  color: #374151;
  line-height: 1.5;
  display: block;
}

/* 图片缩略图 */
.node-images {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
  flex-wrap: wrap;
}

.timeline-node.odd .node-images {
  justify-content: flex-end;
}

.timeline-node.even .node-images {
  justify-content: flex-start;
}

.node-img-thumb {
  width: 112rpx;
  height: 112rpx;
  border-radius: 16rpx;
  background: #f3f4f6;
  border: 1rpx solid #e5e7eb;
}

/* === 节点类型颜色 === */

/* activity: 靛蓝 */
.type-activity .node-type-label {
  background: #e0e7ff;
  color: #4338ca;
}
.type-activity .timeline-dot {
  background: #6366f1;
  box-shadow: 0 0 0 4rpx #6366f1;
}

/* role: 琥珀 */
.type-role .node-type-label {
  background: #fef3c7;
  color: #92400e;
}
.type-role .timeline-dot {
  background: #f59e0b;
  box-shadow: 0 0 0 4rpx #f59e0b;
}

/* life: 粉色 */
.type-life .node-type-label {
  background: #fce7f3;
  color: #9d174d;
}
.type-life .timeline-dot {
  background: #ec4899;
  box-shadow: 0 0 0 4rpx #ec4899;
}

/* ted: 紫色 */
.type-ted .node-type-label {
  background: #ede9fe;
  color: #6b21a8;
}
.type-ted .timeline-dot {
  background: #8b5cf6;
  box-shadow: 0 0 0 4rpx #8b5cf6;
}

/* cert: 绿色 */
.type-cert .node-type-label {
  background: #d1fae5;
  color: #065f46;
}
.type-cert .timeline-dot {
  background: #10b981;
  box-shadow: 0 0 0 4rpx #10b981;
}
