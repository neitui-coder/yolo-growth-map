/* profile-header: 用户资料头部样式 */
/* HTML原型对照: .profile-header */

.profile-header {
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 50%, #3b82f6 100%);
  padding: 48rpx 40rpx 40rpx;
  color: #fff;
  text-align: center;
  position: relative;
  overflow: hidden;
}

.profile-header::before {
  content: '';
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 240rpx;
  height: 240rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
}

.profile-header::after {
  content: '';
  position: absolute;
  bottom: -40rpx;
  left: -40rpx;
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
}

.profile-avatar-container {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  margin: 0 auto 20rpx;
}

.profile-avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  display: block;
  background: #f1f5f9;
}

.avatar-edit-btn {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 52rpx;
  height: 52rpx;
  background: #fff;
  border-radius: 50%;
  border: 4rpx solid #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #64748b;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.edit-icon {
  font-size: 22rpx;
  color: #64748b;
}

.profile-name {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
}

.profile-days {
  font-size: 26rpx;
  opacity: 0.85;
  margin-bottom: 20rpx;
}

.profile-stats {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  margin-bottom: 24rpx;
}

.stat-badge {
  background: rgba(255, 255, 255, 0.15);
  border-radius: 40rpx;
  padding: 10rpx 28rpx;
  font-size: 24rpx;
}

.profile-motto {
  font-size: 26rpx;
  opacity: 0.85;
  margin-bottom: 20rpx;
}

.skill-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 16rpx;
}

.skill-tag {
  background: rgba(255, 255, 255, 0.15);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  border-radius: 32rpx;
  padding: 8rpx 24rpx;
  font-size: 24rpx;
  font-weight: 500;
}
