<view class="member-card {{birthdayClass}}" bindtap="onCardTap">
  <view wx:if="{{displayBirthday}}" class="mc-birthday-ribbon">
    <text>生日月</text>
  </view>
  <!-- 头像（有则图，没有则名字首字）-->
  <view class="mc-avatar-wrap">
    <image wx:if="{{avatarUrl}}" class="mc-avatar" src="{{avatarUrl}}" mode="aspectFill" lazy-load="true" />
    <view wx:else class="mc-avatar mc-avatar-initial">{{avatarInitial}}</view>
    <view wx:if="{{displayBirthday}}" class="mc-birthday-hat">
      <view class="mc-birthday-hat-pom"></view>
      <view class="mc-birthday-hat-cone"></view>
      <view class="mc-birthday-hat-brim"></view>
    </view>
  </view>

  <!-- 名字 + 创始理事/往届/创始人 tag（同行）-->
  <view class="mc-name-row">
    <view class="mc-name">{{user.name}}</view>
    <view wx:if="{{isLishi}}" class="mc-role-badge">创始理事</view>
    <view wx:elif="{{user.memberStatus === 'alumni'}}" class="mc-alumni-badge">往届</view>
    <view wx:if="{{user.isFounder}}" class="mc-founder-badge">创始人</view>
  </view>

  <!-- MBTI -->
  <view class="mc-meta-row">
    <view wx:if="{{user.mbti}}" class="mc-mbti">{{user.mbti}}</view>
    <view wx:if="{{cityDisplay}}" class="mc-city">{{cityDisplay}}</view>
  </view>

  <!-- 底部：成长值 · 加入年数 -->
  <view class="mc-footer">
    <view class="mc-growth" catchtap="onGrowthTap">成长值 {{growthValue}}</view>
    <view class="mc-days">加入 {{yearsSince}} 年</view>
  </view>
</view>
