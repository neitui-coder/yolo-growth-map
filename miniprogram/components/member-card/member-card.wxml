<view class="member-card" bindtap="onCardTap">
  <view wx:if="{{showRank && rank > 0}}" class="mc-rank {{rank === 1 ? 'top1' : rank === 2 ? 'top2' : rank === 3 ? 'top3' : 'top-other'}}">{{rank}}</view>

  <!-- 头像 -->
  <view class="mc-avatar-wrap">
    <image class="mc-avatar" src="{{avatarUrl}}" mode="aspectFill" lazy-load="true" />
    <view wx:if="{{user.isBirthdayMonth}}" class="mc-birthday-hat">
      <view class="mc-birthday-hat-ball"></view>
    </view>
  </view>

  <!-- 名字 + 理事/往届/创始人 tag（同行）-->
  <view class="mc-name-row">
    <view class="mc-name">{{user.name}}</view>
    <view wx:if="{{isLishi}}" class="mc-role-badge">理事</view>
    <view wx:elif="{{user.memberStatus === 'alumni'}}" class="mc-alumni-badge">往届</view>
    <view wx:if="{{user.isFounder}}" class="mc-founder-badge">创始人</view>
  </view>

  <!-- MBTI -->
  <view wx:if="{{user.mbti}}" class="mc-mbti">{{user.mbti}}</view>

  <!-- 地点 -->
  <view wx:if="{{cityDisplay}}" class="mc-city">{{cityDisplay}}</view>

  <!-- 底部：成长值 · 加入年数 -->
  <view class="mc-footer">
    <view class="mc-growth" catchtap="onGrowthTap">成长值 {{growthValue}}</view>
    <view class="mc-days">加入 {{yearsSince}} 年</view>
  </view>

  <!-- 本月生日标签 -->
  <view wx:if="{{user.isBirthdayMonth}}" class="mc-birthday-corner">🎂 本月生日</view>
</view>
