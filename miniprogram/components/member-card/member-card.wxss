.member-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 18rpx 18rpx;
  text-align: center;
  box-shadow: 0 3rpx 12rpx rgba(15, 23, 42, 0.06);
  border: 2rpx solid #e2e8f0;
  min-height: 356rpx;
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
}

.member-card.is-birthday {
  border-color: #fed7aa;
  background: linear-gradient(180deg, #fffaf5 0%, #fff 48%);
  box-shadow: 0 4rpx 18rpx rgba(234, 88, 12, 0.12);
}

.member-card.is-birthday::before,
.member-card.is-birthday::after {
  content: '';
  position: absolute;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #fdba74;
  opacity: 0.9;
}

.member-card.is-birthday::before {
  top: 24rpx;
  left: 28rpx;
}

.member-card.is-birthday::after {
  top: 50rpx;
  left: 48rpx;
  background: #bfdbfe;
}

.mc-birthday-ribbon {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  z-index: 4;
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 72rpx;
  height: 34rpx;
  padding: 0 14rpx;
  border-radius: 999rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
  box-shadow: 0 4rpx 10rpx rgba(249, 115, 22, 0.12);
}

.mc-birthday-ribbon text {
  font-size: 18rpx;
  line-height: 1;
  color: #ea580c;
  font-weight: 800;
}

.card-hover {
  background: #f8fafc;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.mc-avatar-wrap {
  position: relative;
  width: 104rpx;
  height: 104rpx;
  margin: 0 auto 14rpx;
}

.mc-avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: #f1f5f9;
  border: 4rpx solid #e2e8f0;
  display: block;
}

.mc-avatar-initial {
  background: linear-gradient(135deg, #dbeafe 0%, #93c5fd 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 700;
  color: #1d4ed8;
  letter-spacing: 1rpx;
}

.mc-birthday-hat {
  position: absolute;
  top: -20rpx;
  right: -10rpx;
  width: 48rpx;
  height: 58rpx;
  transform: rotate(18deg);
  z-index: 3;
}

.mc-birthday-hat-pom {
  position: absolute;
  top: 0;
  left: 18rpx;
  width: 13rpx;
  height: 13rpx;
  border-radius: 50%;
  background: #fde68a;
  box-shadow: 0 0 0 4rpx rgba(255, 247, 237, 0.85);
  z-index: 4;
}

.mc-birthday-hat-cone {
  position: absolute;
  top: 10rpx;
  left: 5rpx;
  width: 0;
  height: 0;
  border-left: 19rpx solid transparent;
  border-right: 19rpx solid transparent;
  border-bottom: 42rpx solid #fb923c;
}

.mc-birthday-hat-cone::after {
  content: '';
  position: absolute;
  left: -12rpx;
  top: 22rpx;
  width: 24rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  transform: rotate(-18deg);
}

.mc-birthday-hat-brim {
  position: absolute;
  left: 3rpx;
  bottom: 0;
  width: 42rpx;
  height: 11rpx;
  border-radius: 999rpx;
  background: #fed7aa;
  box-shadow: 0 2rpx 4rpx rgba(194, 65, 12, 0.12);
}

.mc-name-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx;
  min-height: 42rpx;
  margin-bottom: 10rpx;
}

.mc-name {
  font-size: 29rpx;
  font-weight: 700;
  color: #1f2937;
  word-break: break-all;
}

.mc-role-row {
  display: flex;
  justify-content: center;
  margin-bottom: 10rpx;
}

.mc-birthday-row {
  display: flex;
  justify-content: center;
  margin-bottom: 10rpx;
}

.mc-founder-badge {
  font-size: 18rpx;
  font-weight: 700;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #7c3aed, #a855f7);
  color: #fff;
}

.mc-alumni-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
  line-height: 1.3;
}

.mc-role-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  background: #fef3c7;
  color: #d97706;
  border: 1rpx solid #fde68a;
  max-width: 100%;
  line-height: 1.3;
  word-break: break-all;
}

.mc-birthday-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  background: #fff1f2;
  color: #e11d48;
  border: 1rpx solid #fecdd3;
  max-width: 100%;
  line-height: 1.3;
  word-break: break-all;
}

.mc-meta-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx;
  min-height: 42rpx;
}

.mc-mbti {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
  line-height: 1.25;
  min-width: 0;
}

.mc-city {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  max-width: 160rpx;
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.25;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.mc-motto {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.4;
  min-height: 62rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.mc-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.mc-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
  color: #64748b;
  max-width: 100%;
  line-height: 1.35;
  word-break: break-word;
  white-space: normal;
}

.mc-footer {
  margin-top: auto;
  padding-top: 14rpx;
}

.mc-growth {
  font-size: 22rpx;
  color: #3b82f6;
  font-weight: 700;
}

.mc-days {
  font-size: 21rpx;
  color: #d1d5db;
  margin-top: 8rpx;
}
