.member-card {
  position: relative;
  display: flex;
  flex-direction: column;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 28rpx;
  text-align: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #e2e8f0;
  min-height: 520rpx;
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
}

.card-hover {
  background: #f8fafc;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.mc-avatar-wrap {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 16rpx;
}

.mc-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: #f1f5f9;
  border: 4rpx solid #e2e8f0;
  display: block;
}

.mc-birthday-hat {
  position: absolute;
  top: -14rpx;
  left: 4rpx;
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 42rpx solid #f97316;
  transform: rotate(-18deg);
  z-index: 2;
}

.mc-birthday-hat::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: -10rpx;
  width: 20rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.7);
}

.mc-birthday-hat-ball {
  position: absolute;
  top: -10rpx;
  left: -6rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fde68a;
  box-shadow: 0 0 0 4rpx rgba(255, 255, 255, 0.2);
}

.mc-name-row {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.mc-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
  word-break: break-all;
}

.mc-role-row {
  display: flex;
  justify-content: center;
  margin-bottom: 10rpx;
}

.mc-birthday-row {
  display: flex;
  justify-content: center;
  margin-bottom: 10rpx;
}

.mc-founder-badge {
  font-size: 18rpx;
  font-weight: 700;
  padding: 2rpx 12rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #7c3aed, #a855f7);
  color: #fff;
}

.mc-alumni-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  background: #f1f5f9;
  color: #64748b;
  border: 1rpx solid #e2e8f0;
  line-height: 1.3;
}

.mc-role-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 600;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  background: #fef3c7;
  color: #d97706;
  border: 1rpx solid #fde68a;
  max-width: 100%;
  line-height: 1.3;
  word-break: break-all;
}

.mc-birthday-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  font-weight: 700;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  background: #fff1f2;
  color: #e11d48;
  border: 1rpx solid #fecdd3;
  max-width: 100%;
  line-height: 1.3;
  word-break: break-all;
}

.mc-mbti {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
  color: #475569;
  margin-bottom: 12rpx;
}

.mc-motto {
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.4;
  min-height: 62rpx;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.mc-tags {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 8rpx;
  margin-top: 12rpx;
}

.mc-tag {
  font-size: 20rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  background: #f1f5f9;
  color: #64748b;
  max-width: 100%;
  line-height: 1.35;
  word-break: break-word;
  white-space: normal;
}

.mc-footer {
  margin-top: auto;
  padding-top: 16rpx;
}

.mc-growth {
  font-size: 22rpx;
  color: #3b82f6;
  font-weight: 600;
}

.mc-days {
  font-size: 22rpx;
  color: #d1d5db;
  margin-top: 12rpx;
}

/* Rank badge */
.mc-rank {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  min-width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 10rpx;
}

.mc-rank.top1 {
  background: #f59e0b;
  color: #fff;
}

.mc-rank.top2 {
  background: #94a3b8;
  color: #fff;
}

.mc-rank.top3 {
  background: #b87333;
  color: #fff;
}

.mc-rank.top-other {
  background: #f3f4f6;
  color: #6b7280;
}
