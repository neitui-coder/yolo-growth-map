.map-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: linear-gradient(180deg, #081a33 0%, #0b2347 100%);
  box-sizing: border-box;
}

.map-header {
  padding: 32rpx 40rpx 12rpx;
}

.map-stat {
  display: flex;
  align-items: baseline;
  gap: 12rpx;
}

.map-stat-num {
  font-size: 72rpx;
  font-weight: 800;
  color: #5eead4;
  text-shadow: 0 0 20rpx rgba(94, 234, 212, 0.6);
}

.map-stat-unit {
  font-size: 28rpx;
  color: #cffafe;
}

.map-stat-sub {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: rgba(207, 250, 254, 0.65);
}

.map-canvas-wrap {
  flex: 1;
  min-height: 0;
  width: 100%;
  height: calc(100vh - 360rpx);
  position: relative;
}

ec-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.map-zoom-ctrl {
  position: absolute;
  right: 28rpx;
  bottom: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  z-index: 50;
}

.zoom-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 20rpx;
  background: rgba(20, 59, 94, 0.92);
  border: 1rpx solid rgba(94, 234, 212, 0.35);
  color: #cffafe;
  font-size: 44rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.zoom-btn:active {
  background: rgba(45, 212, 191, 0.3);
}

.map-footer {
  padding: 16rpx 40rpx calc(28rpx + env(safe-area-inset-bottom));
}

.map-legend {
  display: flex;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
  color: rgba(207, 250, 254, 0.7);
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.dot-lit {
  background: #0fb9b1;
  box-shadow: 0 0 12rpx #2dd4bf;
}

.dot-dim {
  background: #0f2546;
  border: 1rpx solid #1e3a5f;
}

.map-overseas {
  margin-top: 8rpx;
}

.overseas-title {
  font-size: 24rpx;
  color: #cffafe;
}

.overseas-tags {
  margin-top: 12rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.overseas-tag {
  font-size: 22rpx;
  color: #5eead4;
  background: rgba(94, 234, 212, 0.12);
  border: 1rpx solid rgba(94, 234, 212, 0.3);
  padding: 6rpx 18rpx;
  border-radius: 999rpx;
}
