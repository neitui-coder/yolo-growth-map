.stats-page {
  min-height: 100vh;
  background: #f1f5f9;
  padding: 24rpx 24rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.stats-loading {
  text-align: center;
  color: #94a3b8;
  padding-top: 200rpx;
  font-size: 28rpx;
}

.stats-hero {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
  border-radius: 28rpx;
  padding: 36rpx 32rpx;
  color: #fff;
  margin-bottom: 24rpx;
}

.hero-total { display: flex; align-items: baseline; gap: 12rpx; }
.hero-num { font-size: 64rpx; font-weight: 800; }
.hero-unit { font-size: 28rpx; opacity: 0.9; }

.hero-ie { margin-top: 24rpx; }
.ie-bar {
  display: flex;
  height: 48rpx;
  border-radius: 999rpx;
  overflow: hidden;
  font-size: 22rpx;
  font-weight: 700;
}
.ie-e { background: #fbbf24; color: #7c2d12; display: flex; align-items: center; justify-content: center; }
.ie-i { background: rgba(255,255,255,0.28); color: #fff; display: flex; align-items: center; justify-content: center; }
.ie-label { margin-top: 12rpx; font-size: 22rpx; opacity: 0.85; }

.stats-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(15,23,42,0.04);
}

.card-title { font-size: 30rpx; font-weight: 700; color: #1e293b; margin-bottom: 8rpx; }
.card-sub { font-size: 22rpx; color: #94a3b8; margin-bottom: 20rpx; }

.bar-row { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.bar-name { width: 150rpx; font-size: 24rpx; color: #475569; flex-shrink: 0; }
.bar-track { flex: 1; height: 24rpx; background: #f1f5f9; border-radius: 999rpx; overflow: hidden; }
.bar-fill { height: 100%; border-radius: 999rpx; }
.bar-hobby { background: linear-gradient(90deg, #fb7185, #f43f5e); }
.bar-mbti { background: linear-gradient(90deg, #38bdf8, #2563eb); }
.bar-count { width: 48rpx; text-align: right; font-size: 24rpx; color: #1e293b; font-weight: 700; }

.chip-wrap { display: flex; flex-wrap: wrap; gap: 14rpx; }
.stat-chip {
  font-size: 24rpx;
  color: #1d4ed8;
  background: #eff6ff;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
}

.seren-list { display: flex; flex-direction: column; gap: 18rpx; }
.seren-item { display: flex; align-items: center; gap: 16rpx; }
.seren-emoji { font-size: 36rpx; flex-shrink: 0; }
.seren-body { flex: 1; min-width: 0; display: flex; flex-direction: column; }
.seren-text { font-size: 26rpx; color: #1e293b; font-weight: 600; }
.seren-names { font-size: 22rpx; color: #94a3b8; margin-top: 4rpx; }
.seren-count {
  font-size: 22rpx; color: #f43f5e; font-weight: 700; flex-shrink: 0;
  background: #fff1f2; padding: 6rpx 16rpx; border-radius: 999rpx;
}

.stats-footer {
  text-align: center;
  color: #2563eb;
  font-size: 26rpx;
  padding: 20rpx;
}
