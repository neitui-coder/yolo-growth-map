.community-page {
  min-height: 100vh;
  background: #f7f8fa;
}

.nav-bar {
  position: sticky;
  top: 0;
  z-index: 20;
  background: rgba(247, 248, 250, 0.96);
  backdrop-filter: blur(14rpx);
  padding: 26rpx 32rpx 20rpx;
  color: #111827;
  display: flex;
  align-items: center;
  justify-content: center;
  border-bottom: 1rpx solid rgba(226, 232, 240, 0.95);
  box-shadow: 0 4rpx 18rpx rgba(15, 23, 42, 0.04);
}

.nav-title {
  font-size: 32rpx;
  font-weight: 700;
  letter-spacing: 0.2rpx;
}

.community-feed,
.community-skeleton {
  padding: 0 0 120rpx;
}

.feed-card,
.skeleton-card {
  background: #fff;
  border-radius: 0;
  padding: 28rpx 24rpx 24rpx;
  margin-bottom: 0;
  box-shadow: none;
  border: none;
  border-bottom: 1rpx solid #edf1f5;
}

.feed-author-row,
.skeleton-author {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.feed-author-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
}

.feed-avatar-wrap {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  flex-shrink: 0;
}

.feed-avatar,
.skeleton-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 16rpx;
  background: #dbeafe;
}

.feed-avatar.collective {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #eef2ff;
  color: #4f46e5;
  font-size: 20rpx;
  font-weight: 800;
}

.feed-birthday-hat {
  position: absolute;
  top: -14rpx;
  left: 4rpx;
  width: 0;
  height: 0;
  border-left: 16rpx solid transparent;
  border-right: 16rpx solid transparent;
  border-bottom: 38rpx solid #f97316;
  transform: rotate(-18deg);
}

.feed-birthday-hat-ball {
  position: absolute;
  top: -10rpx;
  left: -6rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #fde68a;
}

.feed-author-info {
  flex: 1;
}

.feed-author-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #576b95;
}

.feed-author-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 6rpx;
  color: #94a3b8;
  font-size: 21rpx;
}

.feed-participant-count {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f6fb;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 600;
}

.feed-title {
  margin-top: 14rpx;
  padding-left: 92rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #111827;
  line-height: 1.4;
}

.feed-content {
  margin-top: 10rpx;
  padding-left: 92rpx;
  font-size: 29rpx;
  line-height: 1.68;
  color: #111827;
  word-break: break-word;
}

.feed-participants {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  margin-left: 92rpx;
  padding: 14rpx 16rpx;
  border-radius: 18rpx;
  background: #f7f9fc;
}

.feed-participant-stack {
  display: flex;
  align-items: center;
}

.feed-participant-avatar {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  margin-left: -10rpx;
  background: #dbeafe;
}

.feed-participant-avatar:first-child {
  margin-left: 0;
}

.feed-participant-more {
  color: #64748b;
  font-size: 22rpx;
  font-weight: 700;
}

.feed-images,
.skeleton-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  margin-top: 16rpx;
  margin-left: 92rpx;
}

.feed-image {
  width: 100%;
  height: 188rpx;
  border-radius: 12rpx;
  background: #e2e8f0;
}

.feed-image.single {
  height: 360rpx;
  grid-column: span 3;
}

.feed-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-top: 18rpx;
  margin-left: 92rpx;
  color: #94a3b8;
  font-size: 21rpx;
}

.feed-footer-time {
  flex: 1;
}

.feed-footer-stats {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.feed-load-more {
  text-align: center;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 600;
  padding: 24rpx 0 0;
}

.feed-load-more.muted {
  color: #94a3b8;
}

.community-load-sentinel {
  width: 100%;
  height: 4rpx;
}

.feed-empty {
  padding: 120rpx 48rpx;
  text-align: center;
}

.feed-empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}

.skeleton-lines {
  flex: 1;
}

.skeleton-line,
.skeleton-avatar,
.skeleton-image {
  background: linear-gradient(90deg, #edf3ff 25%, #ffffff 45%, #edf3ff 65%);
  background-size: 240% 100%;
  animation: community-skeleton 1.2s ease infinite;
  border-radius: 16rpx;
}

.feed-card-collective {
  background: linear-gradient(180deg, #ffffff, #fbfdff);
}

.feed-card-birthday .feed-author-name {
  color: #d97706;
}

.feed-card-birthday .feed-content {
  color: #7c2d12;
}

.skeleton-line {
  height: 24rpx;
  margin-top: 10rpx;
}

.skeleton-line-short {
  width: 240rpx;
}

.skeleton-line-mid {
  width: 380rpx;
}

.skeleton-image {
  height: 200rpx;
}

.image-viewer-overlay {
  position: fixed;
  inset: 0;
  background: rgba(15, 23, 42, 0.94);
  z-index: 999;
}

.image-viewer-swiper {
  width: 100vw;
  height: 100vh;
}

.image-viewer-slide {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx 160rpx;
  box-sizing: border-box;
}

.image-viewer-image {
  width: 100%;
  height: 100%;
}

.image-viewer-close {
  position: fixed;
  top: 72rpx;
  right: 32rpx;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: #fff;
  font-size: 24rpx;
  z-index: 1000;
}

@keyframes community-skeleton {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}
