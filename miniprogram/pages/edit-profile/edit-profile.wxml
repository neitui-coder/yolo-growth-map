<!--
  资料编辑页：完整表单，包含所有用户字段
  - 文本输入字段
  - MBTI picker (16 types)
  - Zodiac picker (12 signs)
  - Birthday date picker
  - 逗号分隔的数组字段
-->
<view class="edit-profile-page">
  <view wx:if="{{pageLoading}}" class="edit-loading">资料加载中...</view>

  <block wx:else>
  <view class="form-group">
    <text class="form-label">姓名</text>
    <input class="form-input" value="{{name}}" placeholder="请输入姓名" bindinput="onInput" data-field="name" />
  </view>

  <view class="form-group">
    <text class="form-label">一句话</text>
    <input class="form-input" value="{{motto}}" placeholder="请输入你想展示的一句话" bindinput="onInput" data-field="motto" />
  </view>

  <view class="form-group">
    <text class="form-label">MBTI</text>
    <picker range="{{mbtiOptions}}" value="{{mbtiIndex}}" bindchange="onMbtiChange">
      <view class="form-input picker-value">
        {{mbtiIndex >= 0 ? mbtiOptions[mbtiIndex] : '请选择 MBTI 类型'}}
      </view>
    </picker>
  </view>

  <view class="form-group">
    <text class="form-label">职业</text>
    <input class="form-input" value="{{career}}" placeholder="请输入职业" bindinput="onInput" data-field="career" />
  </view>

  <view class="form-group">
    <text class="form-label">公司</text>
    <input class="form-input" value="{{company}}" placeholder="请输入公司" bindinput="onInput" data-field="company" />
  </view>

  <view class="form-group">
    <text class="form-label">城市</text>
    <input class="form-input" value="{{city}}" placeholder="如：上海" bindinput="onInput" data-field="city" />
  </view>

  <view class="form-group">
    <text class="form-label">生日</text>
    <picker mode="date" value="{{birthday}}" bindchange="onBirthdayChange">
      <view class="form-input picker-value">
        {{birthday || '请选择具体生日（仅用于首页生日月提醒）'}}
      </view>
    </picker>
  </view>

  <view class="form-group">
    <text class="form-label">星座</text>
    <picker range="{{zodiacOptions}}" value="{{zodiacIndex}}" bindchange="onZodiacChange">
      <view class="form-input picker-value">
        {{zodiacIndex >= 0 ? zodiacOptions[zodiacIndex] : '请选择星座'}}
      </view>
    </picker>
  </view>

  <view class="form-group">
    <text class="form-label">教育背景</text>
    <textarea class="form-input form-textarea" value="{{education}}" placeholder="请输入教育背景" auto-height maxlength="-1" bindinput="onInput" data-field="education" />
  </view>

  <view class="form-group">
    <text class="form-label">盖洛普 TOP5</text>
    <input class="form-input" value="{{gallupStr}}" placeholder="用逗号分隔，最多 5 个，如：沟通,适应,学习" bindinput="onInput" data-field="gallupStr" />
  </view>

  <view class="form-group">
    <text class="form-label">爱好（最多 10 个）</text>
    <textarea class="form-input form-textarea" value="{{hobbiesStr}}" placeholder="用逗号分隔，最多 10 个，如：阅读,跑步,旅行" auto-height maxlength="-1" bindinput="onInput" data-field="hobbiesStr" />
  </view>

  <view class="form-group">
    <text class="form-label">擅长领域</text>
    <textarea class="form-input form-textarea" value="{{expertiseStr}}" placeholder="用逗号分隔，如：产品设计,数据分析" auto-height maxlength="-1" bindinput="onInput" data-field="expertiseStr" />
  </view>

  <view class="form-group">
    <text class="form-label">标签</text>
    <textarea class="form-input form-textarea" value="{{tagsStr}}" placeholder="用逗号分隔，如：咖啡爱好者,马拉松跑者" auto-height maxlength="-1" bindinput="onInput" data-field="tagsStr" />
  </view>

  <view class="form-group">
    <text class="form-label">技能认证</text>
    <textarea class="form-input form-textarea" value="{{skillsStr}}" placeholder="用逗号分隔，如：CFA,PMP,AWS SAA" auto-height maxlength="-1" bindinput="onInput" data-field="skillsStr" />
  </view>

  <view class="form-group">
    <text class="form-label">年度目标</text>
    <input class="form-input" value="{{goal}}" placeholder="请输入年度目标" bindinput="onInput" data-field="goal" />
  </view>

  <view class="edit-footer">
    <button class="btn-submit" loading="{{submitting}}" disabled="{{submitting}}" bindtap="onSubmit">{{submitting ? '保存中' : '保存'}}</button>
  </view>
  </block>
</view>
