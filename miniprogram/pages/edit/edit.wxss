/* edit 编辑页面样式 */

.edit-page {
  padding: 32rpx;
  background: #fff;
  min-height: 100vh;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.form-input {
  width: 100%;
  border: 1rpx solid #e2e8f0;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  background: #fff;
}

.picker-value {
  color: #374151;
}

.form-textarea {
  width: 100%;
  border: 1rpx solid #e2e8f0;
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  min-height: 120rpx;
  box-sizing: border-box;
}

/* 已选照片展示区 */
.selected-photos {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
  min-height: 80rpx;
  margin-bottom: 16rpx;
}

.no-photo-hint {
  font-size: 24rpx;
  color: #d1d5db;
}

.selected-photo-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
  border-radius: 16rpx;
  padding: 8rpx 16rpx;
  font-size: 24rpx;
  color: #1d4ed8;
}

.selected-photo-img {
  width: 56rpx;
  height: 56rpx;
  border-radius: 8rpx;
}

.selected-photo-name {
  font-size: 24rpx;
}

.remove-photo {
  margin-left: 4rpx;
  color: #dc2626;
  font-weight: bold;
  font-size: 28rpx;
}

/* 照片选择网格 */
.photo-grid-hint {
  font-size: 24rpx;
  color: #9ca3af;
  margin-bottom: 8rpx;
  display: block;
}

.photo-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 16rpx;
}

.photo-option {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 16rpx;
  border: 6rpx solid transparent;
  opacity: 0.7;
}

.photo-option.selected {
  border-color: #2563eb;
  opacity: 1;
  box-shadow: 0 0 0 4rpx rgba(37, 99, 235, 0.3);
}

/* 保存按钮 */
.btn-submit {
  width: 100%;
  background: #2563eb;
  color: #fff;
  border: none;
  border-radius: 24rpx;
  padding: 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 16rpx;
}

.btn-submit::after {
  border: none;
}
