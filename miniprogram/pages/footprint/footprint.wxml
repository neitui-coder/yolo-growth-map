<view class="footprint-page">
  <view class="nav-bar" style="padding-top: {{navPaddingTop}}px;">
    <view class="nav-title">历史足迹</view>
    <view class="nav-subtitle">{{footprintStatsLabel}}</view>
  </view>

  <view wx:if="{{pageLoading}}" class="footprint-skeleton">
    <view class="skeleton-panel"></view>
    <view class="skeleton-map"></view>
    <view class="skeleton-line"></view>
    <view class="skeleton-line skeleton-line-short"></view>
  </view>

  <view wx:else class="footprint-content">
    <view wx:if="{{footprintSummary}}" class="summary-panel">
      <view class="summary-item">
        <text class="summary-num">{{footprintSummary.chinaCount}}</text>
        <text class="summary-label">中国城市/地区</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="summary-num">{{footprintSummary.worldCount}}</text>
        <text class="summary-label">海外国家/地区</text>
      </view>
      <view class="summary-divider"></view>
      <view class="summary-item">
        <text class="summary-num">{{onlineActivityCount}}</text>
        <text class="summary-label">线上/未定位</text>
      </view>
    </view>

    <view class="map-panel">
      <view class="map-panel-head">
        <view>
          <view class="panel-title">{{mapScope === 'world' ? '世界足迹' : '中国足迹'}}</view>
          <view class="panel-subtitle">{{footprintStatsLabel}}</view>
        </view>
        <view class="scope-switch">
          <view
            class="scope-pill {{mapScope === 'china' ? 'active' : ''}}"
            data-scope="china"
            bindtap="onMapScopeTap"
          >中国</view>
          <view
            class="scope-pill {{mapScope === 'world' ? 'active' : ''}}"
            data-scope="world"
            bindtap="onMapScopeTap"
          >世界</view>
        </view>
      </view>

      <map
        id="footprintMap"
        class="footprint-map"
        latitude="{{mapLatitude}}"
        longitude="{{mapLongitude}}"
        scale="{{mapScale}}"
        markers="{{footprintMarkers}}"
        include-points="{{footprintIncludePoints}}"
        enable-zoom="true"
        enable-scroll="true"
        show-location="{{false}}"
        bindmarkertap="onFootprintMarkerTap"
        bindcallouttap="onFootprintMarkerTap"
      ></map>

      <scroll-view wx:if="{{footprintGroups.length > 0}}" class="location-scroll" scroll-x="true" enhanced="true" show-scrollbar="{{false}}">
        <view class="location-row">
          <view
            class="location-chip {{!selectedFootprint ? 'active' : ''}}"
            bindtap="onResetOverviewTap"
          >
            <text class="location-name">总览</text>
            <text class="location-count">{{footprintGroups.length}}地</text>
          </view>
          <view
            wx:for="{{footprintGroups}}"
            wx:key="key"
            class="location-chip {{selectedFootprint && selectedFootprint.key === item.key ? 'active' : ''}}"
            data-key="{{item.key}}"
            bindtap="onFootprintTap"
          >
            <text class="location-name">{{item.label}}</text>
            <text class="location-count">{{item.activityCount}}场</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view wx:if="{{selectedFootprint}}" class="detail-panel">
      <view class="detail-head">
        <view>
          <view class="detail-title">{{selectedFootprint.label}}</view>
          <view class="detail-subtitle">最近更新 {{selectedFootprint.latestYear}}</view>
        </view>
        <view class="detail-count">{{selectedFootprintActivities.length}} 场</view>
      </view>

      <view
        wx:for="{{selectedFootprintActivities}}"
        wx:key="activityKey"
        class="activity-row"
        data-activity-key="{{item.activityKey}}"
        bindtap="onFootprintActivityTap"
      >
        <view class="activity-main">
          <view class="activity-meta">
            <text>{{item.dateLabel || item.yearMonth}}</text>
            <text wx:if="{{item.typeLabel}}" class="activity-type">{{item.typeLabel}}</text>
          </view>
          <view class="activity-title">{{item.title}}</view>
          <view class="activity-sub">{{item.participantCount}} 人参与</view>
        </view>
        <text class="activity-arrow">›</text>
      </view>
    </view>

    <view wx:elif="{{footprintGroups.length > 0}}" class="detail-panel">
      <view class="detail-head">
        <view>
          <view class="detail-title">{{mapScope === 'world' ? '海外足迹' : '国内足迹'}}</view>
          <view class="detail-subtitle">{{footprintStatsLabel}}</view>
        </view>
      </view>
      <view class="overview-grid">
        <view
          wx:for="{{footprintGroups}}"
          wx:key="key"
          class="overview-location"
          data-key="{{item.key}}"
          bindtap="onFootprintTap"
        >
          <text class="overview-name">{{item.label}}</text>
          <text class="overview-count">{{item.activityCount}} 场活动</text>
        </view>
      </view>
    </view>

    <view wx:else class="empty-state">
      <text class="empty-title">暂无地图足迹</text>
      <text class="empty-sub">线上活动仍会保留在活动列表中</text>
    </view>
  </view>
</view>
