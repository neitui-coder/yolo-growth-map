page {
  background: #f8fafc;
}

.footprint-page {
  min-height: 100vh;
  background: #f8fafc;
  padding-bottom: 64rpx;
}

.nav-bar {
  padding: 24rpx 32rpx 24rpx;
  background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 55%, #2563eb 100%);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.18);
}

.nav-title {
  font-size: 38rpx;
  font-weight: 900;
  color: #fff;
  line-height: 1.2;
}

.nav-subtitle {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.74);
  font-size: 22rpx;
  font-weight: 600;
}

.footprint-content {
  padding: 22rpx 24rpx 0;
}

.summary-panel {
  display: flex;
  align-items: stretch;
  padding: 22rpx 16rpx;
  border-radius: 22rpx;
  background: #fff;
  border: 1rpx solid rgba(226, 232, 240, 0.92);
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.07);
}

.summary-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.summary-num {
  color: #1d4ed8;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
}

.summary-label {
  color: #64748b;
  font-size: 20rpx;
  font-weight: 700;
  line-height: 1.25;
  text-align: center;
}

.summary-divider {
  width: 1rpx;
  background: #e2e8f0;
  margin: 4rpx 2rpx;
}

.map-panel,
.detail-panel {
  margin-top: 22rpx;
  background: #fff;
  border: 1rpx solid rgba(226, 232, 240, 0.92);
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 10rpx 28rpx rgba(15, 23, 42, 0.07);
}

.map-panel-head,
.detail-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx;
}

.panel-title,
.detail-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.25;
}

.panel-subtitle,
.detail-subtitle {
  margin-top: 6rpx;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 600;
}

.scope-switch {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  border: 1rpx solid #e2e8f0;
  flex-shrink: 0;
}

.scope-pill {
  min-width: 70rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 800;
  text-align: center;
  line-height: 1.2;
}

.scope-pill.active {
  background: #0f172a;
  color: #fff;
}

.footprint-map {
  width: 100%;
  height: 560rpx;
  background: #dbeafe;
}

.location-scroll {
  white-space: nowrap;
  padding: 18rpx 20rpx 16rpx;
  border-top: 1rpx solid #edf2f7;
}

.location-row {
  display: inline-flex;
  gap: 12rpx;
}

.location-chip {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #475569;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.location-chip.active {
  color: #0f172a;
  background: #e0f2fe;
  border-color: #7dd3fc;
}

.location-name {
  font-size: 23rpx;
  font-weight: 900;
}

.location-count {
  color: #0891b2;
  font-size: 20rpx;
  font-weight: 800;
}

.detail-count {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #eff6ff;
  color: #2563eb;
  font-size: 22rpx;
  font-weight: 900;
}

.activity-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-top: 1rpx solid #edf2f7;
}

.activity-main {
  min-width: 0;
}

.activity-meta {
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: #64748b;
  font-size: 21rpx;
  font-weight: 700;
}

.activity-type {
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  color: #475569;
}

.activity-title {
  margin-top: 7rpx;
  color: #0f172a;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.35;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.activity-sub {
  margin-top: 6rpx;
  color: #94a3b8;
  font-size: 22rpx;
  font-weight: 600;
}

.activity-arrow {
  flex-shrink: 0;
  color: #94a3b8;
  font-size: 42rpx;
  line-height: 1;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  padding: 0 24rpx 24rpx;
}

.overview-location {
  min-width: 0;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.overview-name {
  display: block;
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 900;
  line-height: 1.25;
}

.overview-count {
  display: block;
  margin-top: 6rpx;
  color: #64748b;
  font-size: 22rpx;
  font-weight: 700;
}

.empty-state {
  margin-top: 22rpx;
  padding: 80rpx 40rpx;
  background: #fff;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.empty-title {
  color: #0f172a;
  font-size: 30rpx;
  font-weight: 800;
}

.empty-sub {
  color: #94a3b8;
  font-size: 24rpx;
}

.footprint-skeleton {
  padding: 22rpx 24rpx;
}

.skeleton-panel,
.skeleton-map,
.skeleton-line {
  background: linear-gradient(90deg, #eef4ff 25%, #ffffff 45%, #eef4ff 65%);
  background-size: 240% 100%;
  animation: sk 1.2s ease infinite;
  border-radius: 22rpx;
}

.skeleton-panel {
  height: 120rpx;
  margin-bottom: 22rpx;
}

.skeleton-map {
  height: 560rpx;
  margin-bottom: 22rpx;
}

.skeleton-line {
  height: 34rpx;
  margin-bottom: 16rpx;
}

.skeleton-line-short {
  width: 60%;
}

@keyframes sk {
  0% { background-position: 100% 50%; }
  100% { background-position: 0 50%; }
}
