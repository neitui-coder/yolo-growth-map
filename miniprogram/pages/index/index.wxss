page {
  background: #edf4ff;
}

.home-page {
  min-height: 100vh;
  padding-bottom: 48rpx;
  background:
    radial-gradient(
      circle at top left,
      rgba(37, 99, 235, 0.16),
      transparent 28%
    ),
    radial-gradient(
      circle at top right,
      rgba(14, 165, 233, 0.12),
      transparent 24%
    ),
    linear-gradient(180deg, #f8fbff 0%, #edf4ff 100%);
}

.nav-bar {
  position: sticky;
  top: 0;
  z-index: 30;
  padding: 24rpx 32rpx 20rpx;
  color: #fff;
  background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 55%, #2563eb 100%);
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.18);
}

.nav-title-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nav-title {
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.nav-badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.24);
  font-size: 20rpx;
  font-weight: 600;
}

.mode-toggle {
  display: inline-flex;
  gap: 8rpx;
  margin: 16rpx 24rpx 0;
  padding: 6rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(191, 219, 254, 0.9);
  box-shadow: 0 8rpx 18rpx rgba(15, 23, 42, 0.06);
}

.mode-chip {
  min-width: 88rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 20rpx;
  line-height: 1.2;
  text-align: center;
  color: #64748b;
  font-weight: 700;
}

.mode-chip.active {
  color: #fff;
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
}

.mode-chip.disabled {
  opacity: 0.55;
}

.section-card {
  margin: 16rpx 24rpx 0;
  padding: 24rpx 0 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(226, 232, 240, 0.92);
  box-shadow: 0 18rpx 40rpx rgba(15, 23, 42, 0.08);
  overflow: hidden;
}

.search-bar {
  padding: 0 20rpx 20rpx;
}

.search-input-wrap {
  position: relative;
  display: flex;
  align-items: center;
}

.search-icon-text {
  position: absolute;
  left: 22rpx;
  font-size: 28rpx;
  z-index: 1;
}

.search-input {
  width: 100%;
  border: 1rpx solid #dbe4f0;
  border-radius: 40rpx;
  padding: 20rpx 72rpx 20rpx 78rpx;
  font-size: 28rpx;
  background: #f8fbff;
}

.search-clear {
  position: absolute;
  right: 16rpx;
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #94a3b8;
}

.filter-pills {
  padding: 0 20rpx 16rpx;
  white-space: nowrap;
}

.filter-pills-inner {
  display: inline-flex;
  gap: 14rpx;
}

.filter-pill {
  display: inline-block;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid #dbe4f0;
  background: #fff;
  color: #64748b;
}

.filter-pill.active {
  background: #2563eb;
  color: #fff;
  border-color: #2563eb;
}

.member-stats-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 0 20rpx 16rpx;
}

.stats-bar-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.alumni-btn {
  font-size: 24rpx;
  color: #475569;
  padding: 10rpx 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid #dbe4f0;
  background: #fff;
}

.alumni-btn.active {
  color: #7c3aed;
  border-color: #c4b5fd;
  background: #f5f3ff;
}

.member-count {
  font-size: 24rpx;
  color: #94a3b8;
}

.sort-btn {
  font-size: 24rpx;
  color: #475569;
  padding: 10rpx 18rpx;
  border-radius: 24rpx;
  border: 1rpx solid #dbe4f0;
  background: #fff;
}

.sort-btn.active {
  color: #1d4ed8;
  border-color: #bfdbfe;
  background: #eff6ff;
}

.inline-loading {
  margin: 0 20rpx 18rpx;
  padding: 14rpx 18rpx;
  border-radius: 18rpx;
  background: #eff6ff;
  display: flex;
  align-items: center;
  gap: 12rpx;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 600;
}

.inline-loading-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #2563eb;
  animation: blink 1s ease-in-out infinite;
}

@keyframes blink {
  0%,
  100% {
    opacity: 0.35;
  }
  50% {
    opacity: 1;
  }
}

.card-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  padding: 0 20rpx 12rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 44rpx 28rpx 40rpx;
  text-align: center;
}

.empty-state-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #0f172a;
}

.empty-state-text {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.load-more {
  padding: 10rpx 20rpx 0;
  text-align: center;
  font-size: 22rpx;
  color: #2563eb;
  font-weight: 600;
}

.load-more.muted {
  color: #94a3b8;
}

.home-load-sentinel {
  width: 100%;
  height: 4rpx;
}

.skeleton-card {
  padding: 24rpx 20rpx 24rpx;
}

.skeleton-line,
.skeleton-chip,
.skeleton-member-card {
  background: linear-gradient(90deg, #eef4ff 25%, #ffffff 45%, #eef4ff 65%);
  background-size: 240% 100%;
  animation: skeleton 1.2s ease infinite;
}

@keyframes skeleton {
  0% {
    background-position: 100% 50%;
  }
  100% {
    background-position: 0 50%;
  }
}

.skeleton-line {
  height: 28rpx;
  border-radius: 999rpx;
  margin-bottom: 18rpx;
}

.skeleton-line-title {
  width: 200rpx;
  height: 36rpx;
}

.skeleton-line-search {
  height: 80rpx;
  margin-top: 12rpx;
}

.skeleton-chip-row {
  display: flex;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.skeleton-chip {
  width: 110rpx;
  height: 44rpx;
  border-radius: 999rpx;
}

.skeleton-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.skeleton-member-card {
  height: 360rpx;
  border-radius: 26rpx;
}
